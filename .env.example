# --- MongoDB (Railway) ---
# In Railway: add a Variable on your API service that references the Mongo plugin.
# Common name from the template: MONGO_URL
#   Name:  MONGO_URL
#   Value: ${{MongoDB.MONGO_URL}}   (pick your Mongo service name from the variable picker)
#
# Or paste the full connection string as MONGODB_URI (Atlas, local, etc.).
#
# MONGO_URL=
# MONGODB_URI=
#
# Test connection from this folder: npm run test-mongo
# One-off URI: TEST_MONGO_URI=mongodb://... npm run test-mongo
#
# Invoice customer data: separate Mongo collections per shop
#   invoice_clients_meit  (tab MeiT)
#   invoice_clients_dpa     (tab DPA)

# --- Pancake e-invoice automation (per shop) ---
# MeiT (falls back to PANCAKE_LOGIN_* / PANCAKE_SHOP_ID if MEIT_* unset)
# PANCAKE_MEIT_SHOP_ID=1021314908
# PANCAKE_MEIT_LOGIN_PHONE=
# PANCAKE_MEIT_LOGIN_PASSWORD=
#
# MeiT tab — two Pancake shops (same customer Mongo, different automation target):
# MeiT Mode (default "Bắt đầu"; falls back to PANCAKE_MEIT_SHOP_ID / PANCAKE_SHOP_ID)
# PANCAKE_MEIT_MODE_SHOP_ID=1021314908
# PANCAKE_MEIT_MODE_API_KEY=
# MeiT Daily (second button on MeiT tab)
# PANCAKE_MEIT_DAILY_SHOP_ID=
# PANCAKE_MEIT_DAILY_API_KEY=
#
# DPA
# PANCAKE_DPA_SHOP_ID=1942925579
# PANCAKE_DPA_LOGIN_PHONE=
# PANCAKE_DPA_LOGIN_PASSWORD=
#
# Legacy names still work for MeiT only:
# PANCAKE_LOGIN_PHONE=
# PANCAKE_LOGIN_PASSWORD=
# PANCAKE_SHOP_ID=
# Optional: comma-separated landing CTAs (default includes Vi + En for pos.pancake.vn).
# PANCAKE_LANDING_CTA_LABELS=Try now,Dùng thử ngay
# Optional: comma-separated login button labels after password.
# PANCAKE_LOGIN_SUBMIT_LABELS=Đăng nhập,Log in
# PANCAKE_LANDING_WAIT_MS=45000
#
# E2E: `npm run test:e2e` runs all WDIO features (login + e-invoice table; Mongo for invoice feature).
# Invoice only: `npm run automation` or POST /run-e2e-tests with body `{"spec":"./wdio/features/pancake-einvoice-automation.feature"}`.
# Quick login-only: `npm run test:e2e:smoke`

# --- Pancake OpenAPI + Webhook ---
# API docs: https://api-docs.pancake.vn/#tag/webhook/put/shopsshop_id
# PANCAKE_API_BASE_URL=https://pos.pages.fm/api/v1
# Per-shop API keys (MeiT may fall back to PANCAKE_API_KEY):
# PANCAKE_MEIT_API_KEY=
# PANCAKE_DPA_API_KEY=
# Legacy (MeiT only): PANCAKE_API_KEY=
# PANCAKE_SHOP_ID=
# PANCAKE_PUBLIC_WEBHOOK_BASE=
# Typical external receiver URL on Railway: https://<app>.up.railway.app/api/pancake/webhook
# PANCAKE_WEBHOOK_RECEIVER_PATH=/webhooks/pancake
# PANCAKE_WEBHOOK_SECRET=
# PANCAKE_WEBHOOK_SECRET_HEADER=x-webhook-secret
# PANCAKE_WEBHOOK_AUTO_RUN=false
