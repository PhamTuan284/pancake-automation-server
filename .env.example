# --- MongoDB (Railway) ---
# In Railway: add a Variable on your API service that references the Mongo plugin.
# Common name from the template: MONGO_URL
#   Name:  MONGO_URL
#   Value: ${{MongoDB.MONGO_URL}}   (pick your Mongo service name from the variable picker)
#
# Or paste the full connection string as MONGODB_URI (Atlas, local, etc.).
#
# MONGO_URL=
# MONGODB_URI=
#
# Test connection from this folder: npm run test-mongo
# One-off URI: TEST_MONGO_URI=mongodb://... npm run test-mongo
#
# Optional collection name (default: invoice_clients)
# MONGODB_INVOICE_COLLECTION=invoice_clients

# --- Pancake automation ---
# E-invoices page (shop-scoped). Default in code matches this if unset.
# PANCAKE_INVOICE_URL=https://pos.pancake.vn/shop/1942925579/e-invoices
# Comma-separated alternates: PANCAKE_INVOICE_URLS=url1,url2
# PANCAKE_LOGIN_PHONE=
# PANCAKE_LOGIN_PASSWORD=
#
# Login: try accounts.pancake.vn first (often more reliable than marketing pos homepage).
# PANCAKE_PREFER_ACCOUNTS_LOGIN=1
# After navigation to e-invoices, wait for URL (ms, default 32000): PANCAKE_INVOICE_NAV_WAIT_MS=45000
# Poll interval (ms): PANCAKE_INVOICE_NAV_POLL_MS=800
# If URL never shows /e-invoices but you want to force the configured URL anyway:
# PANCAKE_INVOICE_URL_TRUST=1   (requires PANCAKE_INVOICE_URL=...)
# Disable Chrome incognito (rare SSO quirks): PANCAKE_INCOGNITO=0
#
# Docker / Linux without DISPLAY: headless is auto. Force: PANCAKE_HEADLESS=1 | PANCAKE_HEADLESS=0
# Browser binary if not default (Docker): CHROME_BIN=/usr/bin/chromium
# Longer wait for slow containers: PANCAKE_CHROMEDRIVER_WAIT_MS=60000
# Reduce webdriver log noise in prod: WDIO_LOG_LEVEL=warn (or error/silent)
# Dashboard URL poll interval (ms), default 1500: PANCAKE_DASHBOARD_POLL_MS=1500
# Optional explicit login URLs (comma-separated) if homepage variant blocks selectors:
# PANCAKE_LOGIN_URLS=https://accounts.pancake.vn/login,https://pos.pancake.vn/login
#
# --- Pancake Open API (webhook registration: PUT /shops/{SHOP_ID}) ---
# Create key: Cấu hình → Nâng cao → Kết nối bên thứ 3 → Webhook/API (see api-docs.pancake.vn).
# PANCAKE_API_KEY=
# PANCAKE_SHOP_ID=1942925579
# PANCAKE_API_BASE=https://pos.pages.fm/api/v1
# Public origin of THIS server (no trailing slash) so the UI shows the full receiver URL:
# PANCAKE_PUBLIC_WEBHOOK_BASE=https://your-api.example.com
# Optional: require this header on incoming POST /webhooks/pancake (set same in Pancake webhook headers).
# PANCAKE_INCOMING_WEBHOOK_SECRET=
# PANCAKE_INCOMING_WEBHOOK_HEADER=x-meit-webhook-secret
# Optional Mongo collection for webhook payloads (default pancake_webhook_events)
# MONGODB_WEBHOOK_EVENTS_COLLECTION=pancake_webhook_events
#
# --- Bundled HRM/CRM (docker-compose.integrations.yml) — UI GET /integrations probes these URLs ---
# Defaults assume Docker maps Horilla → 18080, EspoCRM → 18081 on localhost.
# MEIT_HRM_PUBLIC_URL=http://127.0.0.1:18080
# MEIT_CRM_PUBLIC_URL=http://127.0.0.1:18081
# MEIT_INTEGRATIONS_PROBE_MS=3500
