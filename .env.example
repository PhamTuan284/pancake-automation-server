# --- MongoDB (Railway) ---
# In Railway: add a Variable on your API service that references the Mongo plugin.
# Common name from the template: MONGO_URL
#   Name:  MONGO_URL
#   Value: ${{MongoDB.MONGO_URL}}   (pick your Mongo service name from the variable picker)
#
# Or paste the full connection string as MONGODB_URI (Atlas, local, etc.).
#
# MONGO_URL=
# MONGODB_URI=
#
# Test connection from this folder: npm run test-mongo
# One-off URI: TEST_MONGO_URI=mongodb://... npm run test-mongo
#
# Optional collection name (default: invoice_clients)
# MONGODB_INVOICE_COLLECTION=invoice_clients

# --- Pancake automation ---
# PANCAKE_LOGIN_PHONE=
# PANCAKE_LOGIN_PASSWORD=
# Optional: comma-separated landing CTAs (default includes Vi + En for pos.pancake.vn).
# PANCAKE_LANDING_CTA_LABELS=Try now,Dùng thử ngay
# Optional: comma-separated login button labels after password.
# PANCAKE_LOGIN_SUBMIT_LABELS=Đăng nhập,Log in
# PANCAKE_LANDING_WAIT_MS=45000

# --- Pancake OpenAPI + Webhook ---
# API docs: https://api-docs.pancake.vn/#tag/webhook/put/shopsshop_id
# PANCAKE_API_BASE_URL=https://pos.pages.fm/api/v1
# PANCAKE_API_KEY=
# PANCAKE_SHOP_ID=
# PANCAKE_PUBLIC_WEBHOOK_BASE=
# PANCAKE_WEBHOOK_RECEIVER_PATH=/webhooks/pancake
# PANCAKE_WEBHOOK_SECRET=
# PANCAKE_WEBHOOK_SECRET_HEADER=x-webhook-secret
# PANCAKE_WEBHOOK_AUTO_RUN=false
