# --- MongoDB (Railway) ---
# In Railway: add a Variable on your API service that references the Mongo plugin.
# Common name from the template: MONGO_URL
#   Name:  MONGO_URL
#   Value: ${{MongoDB.MONGO_URL}}   (pick your Mongo service name from the variable picker)
#
# Or paste the full connection string as MONGODB_URI (Atlas, local, etc.).
#
# MONGO_URL=
# MONGODB_URI=
#
# Test connection from this folder: npm run test-mongo
# One-off URI: TEST_MONGO_URI=mongodb://... npm run test-mongo
#
# Optional collection name (default: invoice_clients)
# MONGODB_INVOICE_COLLECTION=invoice_clients

# --- Pancake automation ---
# PANCAKE_LOGIN_PHONE=
# PANCAKE_LOGIN_PASSWORD=
#
# Docker / Linux without DISPLAY: headless is auto. Force: PANCAKE_HEADLESS=1 | PANCAKE_HEADLESS=0
# Browser binary if not default (Docker): CHROME_BIN=/usr/bin/chromium
# Longer wait for slow containers: PANCAKE_CHROMEDRIVER_WAIT_MS=60000
# Reduce webdriver log noise in prod: WDIO_LOG_LEVEL=warn (or error/silent)
# Dashboard URL poll interval (ms), default 1500: PANCAKE_DASHBOARD_POLL_MS=1500
# Optional explicit login URLs (comma-separated) if homepage variant blocks selectors:
# PANCAKE_LOGIN_URLS=https://accounts.pancake.vn/login,https://pos.pancake.vn/login
