{
  "name": "pancake-automation-server",
  "version": "1.0.0",
  "private": true,
  "description": "Express API + WebdriverIO automation for Pancake POS e-invoices",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "automation": "node pancakeAutomation.js"
  },
  "dependencies": {
    "chromedriver": "^146.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "webdriverio": "^8.40.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "nodemonConfig": {
    "watch": [
      "index.js",
      "invoiceExcel.js",
      "pancakeAutomation.js",
      "invoiceData.json",
      ".env"
    ],
    "ignore": [
      "node_modules"
    ]
  }
}
