# Copy to compose.integrations.env (gitignored) for production passwords.
# Quick start: from this folder run `npm run integrations:up`
# (compose uses safe dev defaults — change before production).
#
# With this file:
#   docker compose -f docker-compose.integrations.yml --env-file compose.integrations.env up -d

# --- Horilla (HRM) ---
MEIT_HRM_PORT=18080
MEIT_HRM_DB_PASSWORD=change_me_horilla_pg

# --- EspoCRM (CRM) — must match MEIT_CRM_SITE_URL host/port ---
MEIT_CRM_PORT=18081
MEIT_CRM_SITE_URL=http://localhost:18081
MEIT_CRM_DB_ROOT_PASSWORD=change_me_mariadb_root
MEIT_CRM_DB_PASSWORD=change_me_espo_db
MEIT_CRM_ADMIN_USER=admin
MEIT_CRM_ADMIN_PASSWORD=ChangeMe_Espo_Admin!
